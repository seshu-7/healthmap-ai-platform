# HealthMap AI Platform — Environment Variables
# Copy: cp .env.example .env   Then fill in values.

# OpenAI (required)
OPENAI_API_KEY=sk-your-key-here

# Pinecone (required for RAG)
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=healthmap-clinical
PINECONE_ENVIRONMENT=us-east-1

# Supabase (agent audit logs)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# JWT
JWT_SECRET=change-this-to-a-random-string-at-least-32-characters

# Service URLs (Docker Compose defaults)
AI_SERVICE_URL=http://ai-agent-service:8000
PATIENT_SERVICE_URL=http://mock-patient-service:8080
LAB_SERVICE_URL=http://mock-patient-service:8080
MEDICATION_SERVICE_URL=http://mock-patient-service:8080

# LLM
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
EMBEDDING_MODEL=text-embedding-ada-002

# RAG
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5
